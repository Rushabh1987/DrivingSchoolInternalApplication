# Copy this file to .env and fill in your values before building.
# .env is gitignored and will never be committed.

# -------------------------------------------------------------------
# BUILD-TIME variables (baked into the frontend bundle at docker build)
# Change these before deploying. Do not leave the defaults in production.
# On Railway/Render: set these as "build environment variables".
# -------------------------------------------------------------------
NEXT_PUBLIC_ADMIN_USERNAME=admin
NEXT_PUBLIC_ADMIN_PASSWORD=change_me_in_production

# -------------------------------------------------------------------
# RUNTIME variables (read by the backend process when the container starts)
# On Railway/Render: set these as regular environment variables.
# -------------------------------------------------------------------

# Path to the SQLite database file inside the container.
# Mount a persistent volume at this path to keep data across restarts.
DRIVING_SCHOOL_DB_PATH=/app/backend/data/driving_school.db
